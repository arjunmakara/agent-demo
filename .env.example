# Set these as Environment Variables in the Vercel project settings
# (Project -> Settings -> Environment Variables), not committed here.
ANTHROPIC_API_KEY=your-api-key-here

# Agentic RAG (cancellation / baggage / insurance policy lookups). Optional:
# if any of these three are missing, api/plan.js falls back to plain
# recommendations with no policy lookups.
# Get a Voyage AI key from https://dashboard.voyageai.com/
VOYAGE_API_KEY=your-voyage-api-key-here
# Read/write token for the "travel-agent-demo-blob" Vercel Blob store
# (Storage tab -> travel-agent-demo-blob -> .env.local tab).
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token-here
# Set after running: node scripts/ingest-knowledge-base.js
KB_INDEX_URL=https://your-store-id.private.blob.vercel-storage.com/knowledge-base/index.json
